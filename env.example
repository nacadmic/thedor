# Vercel 프로젝트 설정 → Environment Variables 에서 추가
# 관리자 로그인 비밀번호 (필수) — 12자 이상, 영문+숫자+기호 조합 권장
ADMIN_PASSWORD=your-secret-password

# Blob 스토리지: Vercel 대시보드 → Storage → Blob 생성 시 자동 생성됨
# BLOB_READ_WRITE_TOKEN=...

# 토큰 서명용. 설정 시 비밀번호와 별도로 서명에 사용해 보안 강화
# ADMIN_SECRET=random-long-secret-at-least-32-chars

# --- 카카오 로그인 (관리자 전용, 허용 이메일만 접근)
# 카카오 디벨로퍼스 앱 → 앱 키 → REST API 키
# KAKAO_REST_KEY=your-rest-api-key
# 리다이렉트 URI (카카오 앱에 등록한 값과 동일, 예: https://your-domain.vercel.app/admin)
# KAKAO_REDIRECT_URI=https://your-domain.vercel.app/admin
# 토큰 요청 시 클라이언트 시크릿 사용 시 (앱 키에서 활성화한 경우)
# KAKAO_CLIENT_SECRET=optional-client-secret
# 관리자로 허용: 이메일 또는 카카오 회원 번호(id)
# ALLOWED_ADMIN_EMAILS=admin@example.com
# ALLOWED_KAKAO_IDS=1234567890   (이메일 없이 로그인 시 사용, 403 응답에 kakaoId 나옴)
