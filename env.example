# Vercel 프로젝트 설정 → Environment Variables 에서 추가
# 관리자 로그인 비밀번호 (필수) — 12자 이상, 영문+숫자+기호 조합 권장
ADMIN_PASSWORD=your-secret-password

# Blob 스토리지: Vercel 대시보드 → Storage → Blob 생성 시 자동 생성됨
# BLOB_READ_WRITE_TOKEN=...

# 토큰 서명용. 설정 시 비밀번호와 별도로 서명에 사용해 보안 강화
# ADMIN_SECRET=random-long-secret-at-least-32-chars
